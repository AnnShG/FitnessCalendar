<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/SurveyPage1">

    <fragment
        android:id="@+id/SurveyPage1"
        android:name="com.example.fitnesscalendar.logic.survey.SurveyPage1Fragment"
        android:label="Survey Page 1"
        tools:layout="@layout/survey_page_1">

        <action
            android:id="@+id/action_SurveyPage1_to_SurveyPage2"
            app:destination="@id/SurveyPage2" />
    </fragment>

    <fragment
        android:id="@+id/SurveyPage2"
        android:name="com.example.fitnesscalendar.logic.survey.SurveyPage2Fragment"
        android:label="Survey Page 2"
        tools:layout="@layout/survey_page_2">

        <action
            android:id="@+id/action_SurveyPage2_to_SurveyPage3"
            app:destination="@id/SurveyPage3" />
    </fragment>

    <fragment
        android:id="@+id/SurveyPage3"
        android:name="com.example.fitnesscalendar.logic.survey.SurveyPage3Fragment"
        android:label="Survey Page 3"
        tools:layout="@layout/survey_page_3">

        <action
            android:id="@+id/action_SurveyPage3_to_SurveyPage4"
            app:destination="@id/SurveyPage4" />
    </fragment>

    <fragment
        android:id="@+id/SurveyPage4"
        android:name="com.example.fitnesscalendar.logic.survey.SurveyPage4Fragment"
        android:label="Survey Page 4"
        tools:layout="@layout/survey_page_4">

        <action
            android:id="@+id/action_SurveyPage4_to_CalendarHomePage"
            app:destination="@id/CalendarHomePage" />
    </fragment>

    <fragment
        android:id="@+id/CalendarHomePage"
        android:name="com.example.fitnesscalendar.logic.calendar.CalendarHomePageFragment"
        android:label="Calendar Home"
        tools:layout="@layout/calendar_home_page">

        <action
            android:id="@+id/action_CalendarHomePage_to_AddExerciseScreen"
            app:destination="@+id/AddExerciseScreen" />

        <action
            android:id="@+id/action_CalendarHomePage_to_AddWorkoutScreen"
            app:destination="@+id/AddWorkoutScreen" />

<!--        <action-->
<!--            android:id="@+id/action_CalendarHomePage_to_PlanProgramScreen"-->
<!--            app:destination="@+id/plan_program_screen" />-->
    </fragment>

    <fragment
        android:id="@+id/AddExerciseScreen"
        android:name="com.example.fitnesscalendar.logic.exercise.AddExerciseFragment"
        tools:layout="@layout/add_exercise_screen"/>

    <fragment
        android:id="@+id/AddWorkoutScreen"
        android:name="com.example.fitnesscalendar.logic.workout.AddWorkoutFragment"
        tools:layout="@layout/add_workout_screen"/>

<!--    <fragment-->
<!--        android:id="@+id/PlanProgramScreen"-->
<!--        android:name="com.example.fitnesscalendar.logic.plan.PlanProgramFragment"-->
<!--        tools:layout="@layout/plan_program_screen"/>-->

    <fragment
        android:id="@+id/navigationProfile"
        android:name="com.example.fitnesscalendar.logic.profile.ProfileScreenFragment"
        android:label="Profile"
        tools:layout="@layout/profile_screen">
    </fragment>

    <fragment
        android:id="@+id/navigationGraphs"
        android:name="com.example.fitnesscalendar.logic.graphs.GraphScreenFragment"
        android:label="Profile"
        tools:layout="@layout/graphs_screen">
    </fragment>


</navigation>