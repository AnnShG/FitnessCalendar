<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/home_page_background_colour">

<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="@dimen/guideline_left_percent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="@dimen/guideline_right_percent" />

    <TextView
        android:id="@+id/graphsScreenTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="@string/graphs_title"
        android:layout_marginTop="45dp"
        android:fontFamily="@font/lexend_font"
        android:textSize="25sp"
        android:textStyle="bold"
        android:textColor="@color/text_black_colour"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/consistencyCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"

        app:cardBackgroundColor="@color/button_text_white"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"

        app:layout_constraintTop_toBottomOf="@id/graphsScreenTitle"
        app:layout_constraintStart_toStartOf="@+id/guidelineLeft"
        app:layout_constraintEnd_toEndOf="@id/guidelineRight">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp"
        android:paddingTop="5dp">

    <TextView
        android:id="@+id/disciplineConsistencyGraphLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="@string/discipline_consistency_title"
        android:layout_marginTop="35dp"
        android:fontFamily="@font/lexend_font"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_black_colour"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/monthSelector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/disciplineConsistencyGraphLabel">

        <ImageButton
            android:id="@+id/btnPrevMonth"
            android:layout_width="48dp"
            android:layout_height="48dp"

            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_black_colour"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/currentMonthText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"

            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/text_black_colour"
            tools:text="@string/today_date"

            app:layout_constraintStart_toEndOf="@id/btnPrevMonth"
            app:layout_constraintEnd_toStartOf="@id/btnNextMonth"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnNextMonth"
            android:layout_width="48dp"
            android:layout_height="48dp"

            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_next"
            app:tint="@color/text_black_colour"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/disciplineProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"

        app:indicatorSize="200dp"
        app:trackThickness="15dp"
        app:indicatorColor="@color/graph_progress_bar"
        android:progress="65"
        app:trackCornerRadius="10dp"
        app:trackColor="@color/graph_progress_track_bar"

        app:layout_constraintTop_toBottomOf="@id/monthSelector"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvDisciplinePercent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:fontFamily="@font/lexend_font"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/text_black_colour"
        tools:text="@string/percentCompleted"

        app:layout_constraintTop_toTopOf="@id/disciplineProgressBar"
        app:layout_constraintBottom_toBottomOf="@id/disciplineProgressBar"
        app:layout_constraintStart_toStartOf="@id/disciplineProgressBar"
        app:layout_constraintEnd_toEndOf="@id/disciplineProgressBar" />

    <TextView
        android:id="@+id/tvDisciplineDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="40dp"

        android:fontFamily="@font/lexend_font"
        android:textSize="16sp"
        android:textAlignment="center"
        android:textColor="@color/text_black_colour"
        tools:text="@string/graphSubtitle"

        app:layout_constraintTop_toBottomOf="@id/disciplineProgressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>