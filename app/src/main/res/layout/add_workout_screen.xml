<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:fillViewport="true"
    android:background="@color/home_page_background_colour"
    tools:context=".logic.workout.AddWorkoutFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="@dimen/guideline_left_percent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="@dimen/guideline_right_percent" />

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="45dp"

            android:background="@android:color/transparent"
            android:contentDescription="@string/back_button"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            android:elevation="10dp"
            android:foreground="?attr/selectableItemBackground"

            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_black_colour" />

        <TextView
            android:id="@+id/detailWorkoutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="@string/add_workout_title"
            android:fontFamily="@font/lexend_font"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/text_black_colour"

            app:layout_constraintBottom_toBottomOf="@id/backButton"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/backButton" />

        <ImageView
            android:id="@+id/deleteWorkoutButton"
            android:layout_width="28dp"
            android:layout_height="28dp"

            android:visibility="gone"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:srcCompat="@drawable/ic_delete_bin"
            app:tint="@color/workout_left_side_control_icons_colour"

            app:layout_constraintBottom_toBottomOf="@id/backButton"
            app:layout_constraintEnd_toEndOf="@id/guidelineRight"
            app:layout_constraintTop_toTopOf="@id/backButton" />

        <TextView
            android:id="@+id/workoutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="@string/workout_title_label"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/text_black_colour"

            app:layout_constraintTop_toBottomOf="@id/detailWorkoutTitle"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutTitle"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"

            app:layout_constraintTop_toBottomOf="@id/workoutTitle"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintEnd_toEndOf="@id/guidelineRight">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/workoutTitleInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/workout_title_hint"
                android:fontFamily="@font/lexend_font" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/workoutDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="@string/workout_description"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/text_black_colour"

            app:layout_constraintTop_toBottomOf="@id/textInputLayoutTitle"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutDescription"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"

            app:layout_constraintTop_toBottomOf="@id/workoutDescription"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintEnd_toEndOf="@id/guidelineRight">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/workoutDescriptionInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/workout_description_hint"
                android:fontFamily="@font/lexend_font" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/workoutNotesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="@string/workout_notes"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/text_black_colour"

            app:layout_constraintTop_toBottomOf="@id/textInputLayoutDescription"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutNotes"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:contentDescription="@string/exercise_notes_description"

            app:layout_constraintTop_toBottomOf="@id/workoutNotesText"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintEnd_toEndOf="@id/guidelineRight">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/workoutNotesInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/workout_notes_hint"
                android:fontFamily="@font/lexend_font" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/workoutColourText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="@string/workout_colour_text"
            android:layout_marginTop="35dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/text_black_colour"

            app:layout_constraintTop_toBottomOf="@id/textInputLayoutNotes"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"/>

        <LinearLayout
            android:id="@+id/colorSelectionContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="15dp"

            app:layout_constraintTop_toTopOf="@id/workoutColourText"
            app:layout_constraintBottom_toBottomOf="@id/workoutColourText"
            app:layout_constraintStart_toEndOf="@id/workoutColourText"
            app:layout_constraintEnd_toEndOf="@id/guidelineRight">

        <View
            android:id="@+id/colorGreen"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:elevation="6dp"

            android:background="@drawable/workout_circle_indicator_green" />

        <View
            android:id="@+id/colorBlue"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/workout_circle_indicator_blue" />

        <View
            android:id="@+id/colorPurple"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/workout_circle_indicator_purple" />

        <View
            android:id="@+id/colorRed"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/workout_circle_indicator_red" />

        <View
            android:id="@+id/colorDarkBlue"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/workout_circle_indicator_dark_blue" />

        <View
            android:id="@+id/colorGrey"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/workout_circle_indicator_grey" />

        <View
            android:id="@+id/colorYellow"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/workout_circle_indicator_yellow" />



        </LinearLayout>

        <TextView
            android:id="@+id/WorkoutExercisesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="@string/workout_exercise_text"
            android:layout_marginTop="35dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/text_black_colour"

            app:layout_constraintTop_toBottomOf="@id/workoutColourText"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"/>

<!--        for exercise rows - dynamically adding-->
<!--        <androidx.recyclerview.widget.RecyclerView-->
<!--            android:id="@+id/exercisesRecyclerView"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:nestedScrollingEnabled="false"-->
<!--            app:layout_constraintTop_toBottomOf="@id/WorkoutExercisesText"-->
<!--            app:layout_constraintStart_toStartOf="parent"-->
<!--            app:layout_constraintEnd_toEndOf="parent"/>-->

        <LinearLayout
            android:id="@+id/exercisesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"

            app:layout_constraintTop_toBottomOf="@id/WorkoutExercisesText"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintEnd_toEndOf="@id/guidelineRight">
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addExerciseButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"

            android:text="@string/workout_add_exercise_button"
            android:textAllCaps="false"
            android:textColor="@color/add_exercise_step_text_colour"
            android:textStyle="bold"

            app:icon="@drawable/ic_add_circle"
            app:iconTint="@color/plus_picker_colour"

            android:layout_marginStart="78dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/exercisesContainer"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveWorkoutButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="32dp"

            android:text="@string/save_exercise"
            android:textStyle="bold"
            android:textSize="18sp"
            android:fontFamily="@font/lexend_font"
            app:cornerRadius="13dp"
            app:backgroundTint="@color/exercise_save_button_background_colour"
            android:textColor="@color/exercise_save_text_colour"
            android:foreground="?attr/selectableItemBackground"
            android:elevation="6dp"

            app:layout_constraintTop_toBottomOf="@id/addExerciseButton"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintEnd_toEndOf="@id/guidelineRight"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelWorkoutButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"

            android:text="@string/cancel_exercise"
            android:textStyle="bold"
            android:textSize="18sp"
            android:fontFamily="@font/lexend_font"
            app:cornerRadius="13dp"
            app:backgroundTint="@color/exercise_cancel_button_background_colour"
            android:textColor="@color/exercise_cancel_text_colour"
            android:foreground="?attr/selectableItemBackground"

            app:layout_constraintTop_toBottomOf="@id/saveWorkoutButton"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintEnd_toEndOf="@id/guidelineRight"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
