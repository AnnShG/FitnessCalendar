<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/home_page_background_colour">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/addWorkoutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="@string/add_workout_title"
            android:layout_marginTop="45dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/black_colour"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/workoutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workkout_title"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/addWorkoutTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutTitle"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"

            app:layout_constraintTop_toBottomOf="@id/workoutTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/exerciseNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/exercise_title"
                android:fontFamily="@font/lexend_font" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/workoutDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_description"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/textInputLayoutTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutDescription"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"

            app:layout_constraintTop_toBottomOf="@id/workoutDescription"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/exerciseDescriptionInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/exercise_description"
                android:fontFamily="@font/lexend_font" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/workoutNotesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_notes"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/textInputLayoutDescription"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayoutNotes"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"
            android:contentDescription="@string/exercise_notes_description"

            app:layout_constraintTop_toBottomOf="@id/workoutNotesText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/exerciseNotesInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/workout_notes_description"
                android:fontFamily="@font/lexend_font" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/workoutColourText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_colour_text"
            android:layout_marginTop="35dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/textInputLayoutNotes"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/colorSelectionContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="20dp"
            android:gravity="center_vertical"
            android:padding="20dp"

            app:layout_constraintTop_toTopOf="@id/workoutColourText"
            app:layout_constraintBottom_toBottomOf="@id/workoutColourText"
            app:layout_constraintStart_toEndOf="@id/workoutColourText"
            app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/colorGreen"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/workout_circle_indicator_green" />

        <View
            android:id="@+id/colorBlue"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/workout_circle_indicator_blue" />

        <View
            android:id="@+id/colorPurple"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/workout_circle_indicator_purple" />

        <View
            android:id="@+id/colorRed"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/workout_circle_indicator_red" />

        <View
            android:id="@+id/colorDarkBlue"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/workout_circle_indicator_dark_blue" />

        <ImageView
            android:id="@+id/colorPicker"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"

            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/colour_picker_description"

            android:background="@drawable/workout_circle_picker"
            android:src="@drawable/custom_plus"
            app:tint="@color/plus_picker_colour"
            android:scaleType="fitCenter"/>
        </LinearLayout>

        <TextView
            android:id="@+id/WorkoutExercisesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_exercise_text"
            android:layout_marginTop="35dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/workoutColourText"
            app:layout_constraintStart_toStartOf="parent"/>

<!--        for exercise rows - dynamically adding-->
        <LinearLayout
            android:id="@+id/exercisesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"

            app:layout_constraintTop_toBottomOf="@id/WorkoutExercisesText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

<!--            android:visibility="gone"-->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/exerciseItem1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"

                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"

                app:layout_constraintTop_toBottomOf="@id/WorkoutExercisesText"
                android:background="@drawable/exercise_item_row_background">

        <TextView
            android:id="@+id/leftSideControlIndex"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/workout_exercise_circle_index_bg"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/workout_left_side_control_icons_colour"
            android:textStyle="bold"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.3"/>

        <ImageView
            android:id="@+id/leftSideControlDrag"
            android:layout_width="24dp"
            android:layout_height="24dp"

            app:srcCompat="@drawable/ic_drag_handle"
            app:tint='@color/workout_left_side_control_icons_colour'

            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/leftSideControlIndex"/>

        <ImageView
            android:id="@+id/leftSideControlDelete"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"

            app:srcCompat="@drawable/ic_delete_bin"
            app:tint="@color/dumbbell_colour"

            app:layout_constraintStart_toEndOf="@id/leftSideControlDrag"
            app:layout_constraintTop_toTopOf="@id/leftSideControlDrag"  />

                <FrameLayout
                    android:id="@+id/imageContainer"
                    android:layout_width="150dp"
                    android:layout_height="100dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/image_placeholder_background"
                    android:padding="2dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/leftSideControlDelete"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/exerciseImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/RoundedCorners"
                        app:srcCompat="@drawable/sample_exercise" />
                </FrameLayout>

        <TextView
            android:id="@+id/titleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Title"
            android:layout_marginStart="20dp"

            app:layout_constraintStart_toEndOf="@id/imageContainer"
            app:layout_constraintTop_toTopOf="@id/imageContainer" />

        <TextView
            android:id="@+id/categoriesList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Legs, Chest"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/titleLabel"
            app:layout_constraintStart_toStartOf="@id/titleLabel" />

    </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addExerciseButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="@string/workout_add_exercise_button"
            android:textAllCaps="false"
            android:textColor="@color/add_exercise_step_text_colour"
            android:textStyle="bold"

            app:icon="@drawable/ic_add_circle"
            app:iconTint="@color/dumbbell_colour"

            android:layout_marginStart="90dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/exercisesContainer"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveExerciseButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_margin="32dp"
            android:layout_marginTop="12dp"

            android:text="@string/save_exercise"
            android:textStyle="bold"
            android:textSize="18sp"
            android:fontFamily="@font/lexend_font"
            app:cornerRadius="13dp"
            app:backgroundTint="@color/exercise_save_button_background_colour"
            android:textColor="@color/exercise_save_text_colour"

            app:layout_constraintTop_toBottomOf="@id/addExerciseButton"
            app:layout_constraintBottom_toBottomOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelExerciseButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="@string/cancel_exercise"
            android:textStyle="bold"
            android:textSize="18sp"
            android:fontFamily="@font/lexend_font"
            app:cornerRadius="13dp"
            app:backgroundTint="@color/exercise_cancel_button_background_colour"
            android:textColor="@color/exercise_cancel_text_colour"

            app:layout_constraintTop_toBottomOf="@id/saveExerciseButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
