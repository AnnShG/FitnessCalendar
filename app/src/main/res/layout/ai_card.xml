<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F9F8FF"
        android:padding="20dp">

        <TextView
            android:id="@+id/aiTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_card_title"
            android:textStyle="bold"
            android:textColor="@color/text_black_colour"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/aiSuggestionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/ai_card_text"
            android:textColor="#424242"
            android:lineSpacingMultiplier="1.2"
            android:fontFamily="@font/lexend_font"
            android:textSize="14sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
