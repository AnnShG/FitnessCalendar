<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/survey_background_colour">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp"
        tools:context=".logic.survey.SurveyPage2Fragment">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="@dimen/guideline_left_percent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="@dimen/guideline_right_percent" />

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="30dp"

            android:background="@android:color/transparent"
            android:contentDescription="@string/back_button"
            android:src="@drawable/ic_arrow_back"

            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/survey_button_black" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="@string/about_you"
        android:fontFamily="@font/lexend_font"
        android:textSize="25sp"
        android:textStyle="bold"
        android:textColor="@color/survey_text_black"

        app:layout_constraintBottom_toBottomOf="@id/backButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/backButton" />



    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"

        android:text="@string/survey_name"
        android:fontFamily="@font/lexend_font"
        android:textSize="@dimen/text_size"
        android:textStyle="normal"
        android:textColor="@color/survey_text_black"
        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@id/backButton" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="@string/survey_age"
        android:textSize="@dimen/text_size"
        android:textStyle="normal"
        android:textColor="@color/survey_text_black"
        android:fontFamily="@font/lexend_font"

        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@id/textInputLayout" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/textInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"

        android:hint="@string/enter_your_name"
        app:boxStrokeColor="@color/button_stroke_colour"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="@color/chip_bg_colour"

        app:layout_constraintEnd_toEndOf="@id/guidelineRight"
        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@id/textView2">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/userInputName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:textColor="@color/survey_text_black"
            android:textSize="16sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/textInputLayoutBirthDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"

        android:hint="@string/enter_your_db"

        app:layout_constraintEnd_toEndOf="@id/guidelineRight"
        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@id/textView3"

        app:boxStrokeColor="@color/button_stroke_colour"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="@color/chip_bg_colour">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/userInputBirthDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:focusable="false"
            android:clickable="true"

            android:textColor="@color/survey_text_black"
            android:textSize="16sp" />

    </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/textView4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"

            android:text="@string/survey_gender"
            android:textSize="@dimen/text_size"
            android:textStyle="normal"
            android:textColor="@color/survey_text_black"
            android:fontFamily="@font/lexend_font"

            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toBottomOf="@id/textInputLayoutBirthDate"
            />

    <!-- Container for Gender Buttons -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/genderContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintTop_toBottomOf="@id/textView4"
        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintEnd_toEndOf="@id/guidelineRight">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonMale"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:text="@string/male_gender"
            android:textAllCaps="false"
            android:layout_marginEnd="4dp"

            android:textSize="@dimen/text_size"
            app:cornerRadius="8dp"
            android:textStyle="normal"
            android:fontFamily="@font/lexend_font"
            android:textColor="@color/survey_text_black"

            android:backgroundTint="@android:color/white"
            app:strokeColor="@color/button_stroke_colour"
            app:strokeWidth="1dp"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/buttonFemale" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonFemale"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:text="@string/female_gender"
            android:textAllCaps="false"
            android:fontFamily="@font/lexend_font"
            android:textSize="@dimen/text_size"
            app:cornerRadius="8dp"
            android:textStyle="normal"
            android:textColor="@color/survey_text_black"

            android:backgroundTint="@android:color/white"
            app:strokeColor="@color/button_stroke_colour"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@+id/buttonMale"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonNoAnswer"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:text="@string/no_gender"
            android:textAllCaps="false"
            android:fontFamily="@font/lexend_font"
            android:textSize="@dimen/text_size"
            app:cornerRadius="8dp"
            android:textStyle="normal"
            android:textColor="@color/survey_text_black"

            android:backgroundTint="@android:color/white"
            app:strokeColor="@color/button_stroke_colour"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/buttonMale"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.button.MaterialButton
        android:id="@+id/continueButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="24dp"

        android:textSize="18sp"
        app:cornerRadius="13dp"
        android:textStyle="bold"
        android:fontFamily="@font/lexend_font"
        app:backgroundTint="@color/continue_button_background_colour"
        android:foreground="?attr/selectableItemBackground"
        android:textColor="@color/button_text_white"
        android:text="@string/survey_continue"

        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintEnd_toEndOf="@id/guidelineRight"
        app:layout_constraintTop_toBottomOf="@id/genderContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="1.0" />

</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>