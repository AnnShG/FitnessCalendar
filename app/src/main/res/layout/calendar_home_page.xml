<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_page_background_colour">

<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/calendar_home_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_page_background_colour"
    tools:context=".logic.calendar.CalendarHomePageFragment">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.01" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_stats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.01" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/mindsetButton"
        android:layout_width="0dp"
        android:layout_height="60dp"

        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/lexend_font"
        android:textColor="@color/mindset_button_text_colour"
        android:text="@string/mindset_button_text"

        app:cornerRadius="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/mindset_button_stroke_colour"
        app:backgroundTint="@color/mindset_button_fill_colour"
        android:foreground="?attr/selectableItemBackground"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_top"
        android:layout_marginTop="25dp"
        android:layout_marginStart="@dimen/margin_left" />

    <LinearLayout
        android:id="@+id/training_stats_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_stats">

    <TextView
        android:id="@+id/calendar_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="@string/calendar_title_text"
        android:layout_marginTop="120dp"
        android:fontFamily="@font/lexend_font"
        android:textSize="16sp"
        android:textStyle="normal"
        android:textColor="@color/survey_text_black"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/training_days_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="@string/calendar_training_count_default"
        android:fontFamily="@font/lexend_font"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/survey_text_black"
        android:layout_marginTop="4dp" />
</LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/plusButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        app:fabCustomSize="48dp"
        app:maxImageSize="44dp"

        app:srcCompat="@drawable/custom_plus"
        app:backgroundTint="@color/plus_button_background_colour"
        app:tint="@color/plus_button_colour"
        android:contentDescription="@string/plus_button_description"
        style="@style/Widget.MaterialComponents.FloatingActionButton"
        android:foreground="?attr/selectableItemBackground"

        android:layout_marginTop="120dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.8"
        app:layout_constraintStart_toEndOf="@id/training_stats_container"
        app:layout_constraintTop_toTopOf="@id/training_stats_container"
        app:layout_constraintBottom_toBottomOf="@id/training_stats_container" />

    <LinearLayout
        android:id="@+id/calendar_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/training_stats_container">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/calendar_prev_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="35dp"
            android:layout_height="55dp"
            android:layout_gravity="center"
            android:layout_weight="1"

            android:contentDescription="@string/arrow_back_description"
            app:icon="@drawable/ic_arrow_back"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/text_black_colour"
            app:iconSize="32dp"
            app:tint="@color/text_black_colour"
            android:foreground="?attr/selectableItemBackground" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/monthAndYear"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:gravity="center"
            android:text=""
            android:fontFamily="@font/lexend_font"
            android:textAppearance="@style/TextAppearance.AppCompat.Headline" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/calendar_next_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="35dp"
            android:layout_height="55dp"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:padding="16dp"
            app:icon="@drawable/ic_arrow_next"
            android:contentDescription="@string/arrow_next_description"

            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/text_black_colour"
            app:iconSize="32dp"
            app:tint="@color/text_black_colour"
            android:foreground="?attr/selectableItemBackground" />
    </LinearLayout>

    <!-- days header -->
    <LinearLayout
        android:id="@+id/calendar_header"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"

        app:layout_constraintTop_toBottomOf="@id/calendar_navigation">

        <TextView style="@style/CalendarHeaderStyle" android:text="@string/monday" />
        <TextView style="@style/CalendarHeaderStyle" android:text="@string/tuesday" />
        <TextView style="@style/CalendarHeaderStyle" android:text="@string/wednesday" />
        <TextView style="@style/CalendarHeaderStyle" android:text="@string/thursday" />
        <TextView style="@style/CalendarHeaderStyle" android:text="@string/friday" />
        <TextView style="@style/CalendarHeaderStyle" android:text="@string/saturday" />
        <TextView style="@style/CalendarHeaderStyle" android:text="@string/sunday" />
    </LinearLayout>

    <!-- days view -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/calendar_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        app:layoutManager="GridLayoutManager"
        app:spanCount="7"
        app:layout_constraintTop_toBottomOf="@id/calendar_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <GridLayout
        android:id="@+id/legendContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_marginTop="8dp"
        android:columnCount="2"
        android:alignmentMode="alignMargins"
        app:layout_constraintTop_toBottomOf="@id/calendar_recycler_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
    <include
        android:id="@+id/dailyPlanWindow"
        layout="@layout/plan_daily_window" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>