<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- 1. The Workout Color Dot -->
        <View
            android:id="@+id/workoutColorDot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/circle_dot_event"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:backgroundTint="@color/daily_workout_item_colour" />

        <!-- 2. The Workout Title -->
        <TextView
            android:id="@+id/workoutTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/lexend_font"
            android:textColor="@color/text_black_colour"
            android:textSize="15sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnDeleteDaily"
            app:layout_constraintStart_toEndOf="@id/workoutColorDot"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Beginner Full Body" />

        <!-- 3. The Bin (Delete) Icon -->
        <ImageView
            android:id="@+id/btnDeleteDaily"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:padding="2dp"
            android:src="@drawable/ic_delete_bin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/workoutCheckbox"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#757575" />

        <!-- 4. The Completion Checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/workoutCheckbox"
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:buttonTint="@color/text_black_colour"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:useMaterialThemeColors="false" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>