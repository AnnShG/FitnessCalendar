<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:orientation="vertical">

    <ImageButton
        android:id="@+id/btnViewDetails"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_margin="8dp"
        android:background="@drawable/circle_white_for_eye"
        app:srcCompat="@drawable/ic_eye"
        android:visibility="visible"
        app:tint="@color/exercises_detail_black_colour"
        android:layout_gravity="top|end"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/exerciseMedia"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="fitCenter"
        app:shapeAppearanceOverlay="@style/RoundedCornersGallery"
        app:srcCompat="@drawable/sample_exercise" />

    <TextView
        android:id="@+id/exerciseTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/lexend_font"
        android:text="@string/workout_item_galley_image_title"
        android:gravity="center"
        android:textColor="@color/text_black_colour"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>