<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:fillViewport="true"
    android:background="@color/home_page_background_colour"
    tools:context=".logic.exercise.AddExerciseFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/allWorkoutsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="@string/workout_list_title"
            android:layout_marginTop="45dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/black_colour"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="@dimen/margin_left"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="20dp"

            app:layout_constraintTop_toBottomOf="@id/allWorkoutsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchWorkoutsField"
                android:layout_width="300dp"
                android:layout_height="50dp" />

            <ImageView
                android:id="@+id/filterWorkoutsButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="@dimen/margin_left"
                android:layout_marginStart="20dp"

                app:srcCompat="@drawable/ic_filter"
                android:contentDescription="@string/workout_filter_icon_description"
                app:tint="@color/workout_left_side_control_icons_colour" />
        </LinearLayout>

        <TextView
            android:id="@+id/filteredWorkouts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_filtered_text"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/black_colour"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerContainer" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>