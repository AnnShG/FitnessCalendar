<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:fillViewport="true"
    android:background="@color/home_page_background_colour"
    tools:context=".logic.workout.WorkoutDetailFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="25dp"
            android:layout_marginStart="@dimen/margin_left"
            android:background="@android:color/transparent"
            android:contentDescription="@string/back_button"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/black_colour" />

        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="20dp"
            android:gravity="center_vertical"
            android:padding="20dp"

            app:layout_constraintTop_toTopOf="@id/backButton"
            app:layout_constraintBottom_toBottomOf="@id/backButton"
            app:layout_constraintStart_toEndOf="@id/backButton"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:id="@+id/colourIndicator"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/workout_circle_indicator_green" />

        <TextView
            android:id="@+id/addWorkoutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"

            android:text="@string/workout_item_title"
            android:fontFamily="@font/lexend_font"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/black_colour"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/colorIndicator"
            app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/edit_workout_button"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="40dp"

                app:srcCompat="@drawable/ic_edit_field"
                app:tint="@color/workout_left_side_control_icons_colour"

                app:layout_constraintStart_toEndOf="@id/addWorkoutTitle"
                app:layout_constraintTop_toTopOf="parent" />
        </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/gallerySection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/galleryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:fontFamily="@font/lexend_font"
            android:text="@string/exercises"
            android:textColor="@color/black_colour"
            android:textSize="20sp"
            android:textStyle="bold"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/exerciseCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/lexend_font"
            android:text="12 exercises"
            android:textColor="@color/plus_button_background_colour"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@id/galleryTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/galleryTitle" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvExerciseGallery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/galleryTitle"
            tools:listitem="@layout/workout_item_gallery_image" />

    </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/workoutDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_item_description"
            android:layout_marginTop="60dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/gallerySection"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/workoutDescriptionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_item_description_text"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/workoutDescription"
            app:layout_constraintStart_toStartOf="parent" />


        <TextView
            android:id="@+id/workoutNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_item_notes"
            android:layout_marginTop="40dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/workoutDescriptionText"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/workoutNotesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_item_notes_text"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/workoutNotes"
            app:layout_constraintStart_toStartOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
