<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/workout_detail_card_bg_colour"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="#F5F5F5"
    app:strokeWidth="1dp">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="30dp"
        android:paddingStart="16dp"
        android:paddingBottom="20dp"
        android:paddingEnd="5dp">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/workoutCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            app:buttonTint="@color/plus_button_background_colour"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"

            android:visibility="gone"
            tools:visibility="visible"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/workoutIndicatorBar"
            android:layout_width="5dp"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/workout_indicator_rounded"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/workoutCheckbox"
            app:layout_constraintTop_toTopOf="parent"
            tools:backgroundTint="@color/workout_indicator_dark_blue_colour" />

        <ImageButton
            android:id="@+id/btnViewDetails"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/circle_white_for_eye"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_eye"
            app:tint="@color/text_black_colour" />

        <TextView
            android:id="@+id/workoutTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"

            android:fontFamily="@font/lexend_font"
            android:textColor="@color/text_black_colour"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="@string/workout_title_text"

            app:layout_constraintEnd_toStartOf="@id/btnViewDetails"
            app:layout_constraintStart_toEndOf="@id/workoutIndicatorBar"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/workoutDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"

            android:ellipsize="end"
            android:fontFamily="@font/lexend_font"
            android:maxLines="2"
            android:textColor="@color/survey_text_black"
            android:textSize="14sp"
            tools:text="@string/workout_title_description"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/workoutTitle"
            app:layout_constraintStart_toStartOf="@id/workoutTitle"
            app:layout_constraintTop_toBottomOf="@id/workoutTitle" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>