<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:id="@+id/survey3Root"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/survey_background_colour">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp"
        tools:context=".logic.survey.SurveyPage3Fragment">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="@dimen/guideline_left_percent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="@dimen/guideline_right_percent" />

    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="30dp"

        android:background="@android:color/transparent"
        android:contentDescription="@string/back_button"
        android:src="@drawable/ic_arrow_back"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/survey_button_black" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="@string/main_goal"
        android:fontFamily="@font/lexend_font"
        android:textSize="25sp"
        android:textStyle="bold"
        android:textColor="@color/survey_text_black"

        app:layout_constraintBottom_toBottomOf="@id/backButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/backButton" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"

        android:text="@string/choose_or_write"
        android:fontFamily="@font/lexend_font"
        android:textSize="16sp"
        android:textStyle="normal"
        android:textColor="@color/survey_text_black"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textView"/>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/option1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"

        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"

        app:strokeColor="@color/button_stroke_colour"
        android:backgroundTint="@color/chip_bg_colour"
        app:strokeWidth="1dp"

        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintEnd_toEndOf="@id/guidelineRight"
        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@id/textView7">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp">

            <!-- First line (bold) -->
            <TextView
                android:id="@+id/cardLoseWeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/lose_weight"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Second line -->
            <TextView
                android:id="@+id/textSubtitle1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/lose_weight_add"
                android:textSize="12sp"
                android:textStyle="normal"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle1"
                app:layout_constraintStart_toStartOf="@id/cardLoseWeight"
                app:layout_constraintTop_toBottomOf="@id/cardLoseWeight" />

            <!-- Right selection circle -->
            <ImageView
                android:id="@+id/circle1"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/survey_circle_unselected"
                android:contentDescription="@string/selection_circle_description"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/option2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"

        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"

        app:layout_constraintWidth_max="380dp"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintEnd_toEndOf="@id/guidelineRight"
        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@id/option1"

        app:strokeColor="@color/button_stroke_colour"
        android:backgroundTint="@color/chip_bg_colour"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            >

            <!-- First line (bold) -->
            <TextView
                android:id="@+id/textTitle2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/build_muscle"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Second line -->
            <TextView
                android:id="@+id/textSubtitle2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/build_muscle_add"
                android:textSize="12sp"
                android:textStyle="normal"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle2"
                app:layout_constraintStart_toStartOf="@id/textTitle2"
                app:layout_constraintTop_toBottomOf="@id/textTitle2" />

            <!-- Right selection circle -->
            <ImageView
                android:id="@+id/circle2"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/survey_circle_unselected"
                android:contentDescription="@string/selection_circle_description"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/option3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        android:layout_marginTop="12dp"

        app:layout_constraintWidth_max="380dp"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintEnd_toEndOf="@id/guidelineRight"
        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@id/option2"

        app:strokeColor="@color/button_stroke_colour"
        android:backgroundTint="@color/chip_bg_colour"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            >

            <!-- First line (bold) -->
            <TextView
                android:id="@+id/textTitle3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/get_stronger"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Second line -->
            <TextView
                android:id="@+id/textSubtitle3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/get_stronger_add"
                android:textSize="12sp"
                android:textStyle="normal"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle3"
                app:layout_constraintStart_toStartOf="@id/textTitle3"
                app:layout_constraintTop_toBottomOf="@id/textTitle3" />

            <!-- Right selection circle -->
            <ImageView
                android:id="@+id/circle3"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/survey_circle_unselected"
                android:contentDescription="@string/selection_circle_description"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/option4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        android:layout_marginTop="12dp"

        app:layout_constraintWidth_max="380dp"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintEnd_toEndOf="@id/guidelineRight"
        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@id/option3"

        app:strokeColor="@color/button_stroke_colour"
        android:backgroundTint="@color/chip_bg_colour"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            >

            <!-- First line (bold) -->
            <TextView
                android:id="@+id/textTitle4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/stay_fit"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Second line -->
            <TextView
                android:id="@+id/textSubtitle4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/stay_fit_add"
                android:textSize="12sp"
                android:textStyle="normal"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle4"
                app:layout_constraintStart_toStartOf="@id/textTitle4"
                app:layout_constraintTop_toBottomOf="@id/textTitle4" />

            <!-- Right selection circle -->
            <ImageView
                android:id="@+id/circle4"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/survey_circle_unselected"
                android:contentDescription="@string/selection_circle_description"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/option5"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        android:layout_marginTop="12dp"

        app:layout_constraintWidth_max="380dp"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintEnd_toEndOf="@id/guidelineRight"
        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@id/option4"

        app:strokeColor="@color/button_stroke_colour"
        android:backgroundTint="@color/chip_bg_colour"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            >

            <!-- First line (bold) -->
            <TextView
                android:id="@+id/textTitle5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/recover_after_injury"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Second line -->
            <TextView
                android:id="@+id/textSubtitle5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/recover_after_injury_add"
                android:textSize="12sp"
                android:textStyle="normal"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle5"
                app:layout_constraintStart_toStartOf="@id/textTitle5"
                app:layout_constraintTop_toBottomOf="@id/textTitle5" />

            <!-- Right selection circle -->
            <ImageView
                android:id="@+id/circle5"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/survey_circle_unselected"
                android:contentDescription="@string/selection_circle_description"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/option6"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        android:layout_marginTop="12dp"

        app:layout_constraintWidth_max="380dp"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintEnd_toEndOf="@id/guidelineRight"
        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@id/option5"

        app:strokeColor="@color/button_stroke_colour"
        android:backgroundTint="@color/chip_bg_colour"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            >

            <!-- First line (bold) -->
            <TextView
                android:id="@+id/cardStayActive"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/stay_active"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle6"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Second line -->
            <TextView
                android:id="@+id/textSubtitle6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/stay_active_add"
                android:textSize="12sp"
                android:textStyle="normal"
                android:paddingLeft="35dp"
                android:paddingRight="35dp"

                app:layout_constraintEnd_toStartOf="@id/circle6"
                app:layout_constraintStart_toStartOf="@id/cardStayActive"
                app:layout_constraintTop_toBottomOf="@id/cardStayActive" />

            <!-- Right selection circle -->
            <ImageView
                android:id="@+id/circle6"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/survey_circle_unselected"
                android:contentDescription="@string/selection_circle_description"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/textInputLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/type_own"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginTop="12dp"

        app:layout_constraintEnd_toEndOf="@id/guidelineRight"
        app:layout_constraintStart_toStartOf="@id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@id/option6"
        app:layout_constraintWidth_max="380dp"
        app:layout_constraintHorizontal_bias="0.5"

        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"

        app:boxStrokeColor="@color/button_stroke_colour"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="@color/chip_bg_colour">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/userInputGoal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:textColor="@color/survey_text_black"
            android:textSize="16sp" />
    </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/continueButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp"

            android:textSize="18sp"
            app:cornerRadius="13dp"
            android:textStyle="bold"
            app:backgroundTint="@color/continue_button_background_colour"
            android:foreground="?attr/selectableItemBackground"
            android:textColor="@color/button_text_white"
            android:text="@string/survey_continue"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/guidelineRight"
            app:layout_constraintStart_toStartOf="@id/guidelineLeft"
            app:layout_constraintTop_toBottomOf="@id/textInputLayout"
            app:layout_constraintVertical_bias="1.0" />

</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>