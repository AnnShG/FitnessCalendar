<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:gravity="top">

    <!-- Number Circle -->
    <TextView
        android:id="@+id/tvStepIndex"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="20dp"
        android:background="@drawable/workout_exercise_circle_index_bg"
        android:gravity="center"
        android:text="1"
        android:textColor="@color/workout_left_side_control_icons_colour"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Step Description (Wraps Text) -->
    <TextView
        android:id="@+id/tvStepContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:fontFamily="@font/lexend_font"
        android:text="This is a step description for the exercises. This is a step description for the exercises. This is a step description for the exercises. "
        android:textColor="@color/black_colour"
        android:textSize="16sp"
        android:lineSpacingExtra="4sp" />

</LinearLayout>