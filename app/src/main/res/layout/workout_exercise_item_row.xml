<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".logic.workout.AddWorkoutFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/exerciseItem1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/leftSideControlIndex"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/workout_exercise_circle_index_bg"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/workout_left_side_control_icons_colour"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.3"/>

        <ImageView
            android:id="@+id/leftSideControlDelete"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="25dp"
            android:layout_marginStart="4dp"
            app:srcCompat="@drawable/ic_delete_bin"
            app:tint="@color/workout_left_side_control_icons_colour"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="@id/leftSideControlIndex"
            app:layout_constraintEnd_toEndOf="@id/leftSideControlIndex"
            app:layout_constraintTop_toBottomOf="@id/leftSideControlIndex" />

        <FrameLayout
            android:id="@+id/imageContainer"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginStart="20dp"
            android:background="@drawable/image_placeholder_background"
            android:padding="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/leftSideControlDelete"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/exerciseImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                app:shapeAppearanceOverlay="@style/RoundedCorners"
                app:srcCompat="@drawable/sample_exercise" />

            <VideoView
                android:id="@+id/exerciseVideo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/titleLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/exercise_item_grid_title_text"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintStart_toEndOf="@id/imageContainer"
            app:layout_constraintTop_toTopOf="@id/imageContainer"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/categoriesList"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/exercise_item_grid_category_text"
            android:layout_marginTop="25dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/titleLabel"
            app:layout_constraintStart_toStartOf="@id/titleLabel"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>