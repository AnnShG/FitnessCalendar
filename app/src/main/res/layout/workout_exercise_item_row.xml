<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".logic.workout.AddWorkoutFragment">

    <!--            android:visibility="gone"-->
    <!--                android:background="@drawable/exercise_item_row_background"-->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/exerciseItem1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"

        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/leftSideControlIndex"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/workout_exercise_circle_index_bg"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/workout_left_side_control_icons_colour"
            android:textStyle="bold"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.3"/>

        <ImageView
            android:id="@+id/leftSideControlDrag"
            android:layout_width="24dp"
            android:layout_height="24dp"

            app:srcCompat="@drawable/ic_drag_handle"
            app:tint='@color/workout_left_side_control_icons_colour'

            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/leftSideControlIndex"/>

        <ImageView
            android:id="@+id/leftSideControlDelete"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"

            app:srcCompat="@drawable/ic_delete_bin"
            app:tint="@color/workout_left_side_control_icons_colour"

            app:layout_constraintStart_toEndOf="@id/leftSideControlDrag"
            app:layout_constraintTop_toTopOf="@id/leftSideControlDrag"  />

        <FrameLayout
            android:id="@+id/imageContainer"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/image_placeholder_background"
            android:padding="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/leftSideControlDelete"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/exerciseImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                app:shapeAppearanceOverlay="@style/RoundedCorners"
                app:srcCompat="@drawable/sample_exercise" />
        </FrameLayout>

        <TextView
            android:id="@+id/titleLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/exercise_item_grid_title_text"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="16dp"

            app:layout_constraintStart_toEndOf="@id/imageContainer"
            app:layout_constraintTop_toTopOf="@id/imageContainer"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/categoriesList"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/exercise_item_grid_category_text"
            android:layout_marginTop="25dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/titleLabel"
            app:layout_constraintStart_toStartOf="@id/titleLabel"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>