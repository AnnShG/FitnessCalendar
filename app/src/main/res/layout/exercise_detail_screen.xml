<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:fillViewport="true"
    android:background="@color/home_page_background_colour"
    tools:context=".logic.exercise.ExerciseDetailFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/editExerciseButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="@dimen/margin_right"
            android:layout_marginTop="45dp"

            app:srcCompat="@drawable/ic_edit_field"
            app:tint="@color/workout_left_side_control_icons_colour"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="20dp"
            android:gravity="center_vertical"
            android:padding="20dp"

            app:layout_constraintTop_toTopOf="@id/editExerciseButton"
            app:layout_constraintBottom_toBottomOf="@id/editExerciseButton"
            app:layout_constraintStart_toEndOf="@id/editExerciseButton"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/addExerciseTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"

                android:text="@string/exercise_item_title"
                android:fontFamily="@font/lexend_font"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textColor="@color/black_colour"

                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/delete_exercise_button"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="70dp"

                app:srcCompat="@drawable/ic_delete_bin"
                app:tint="@color/workout_left_side_control_icons_colour"

                app:layout_constraintStart_toEndOf="@id/addExerciseTitle"
                app:layout_constraintTop_toTopOf="parent" />
        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/mainExerciseImage"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedCorners"
            app:srcCompat="@drawable/sample_exercise"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerContainer" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/categoryChipGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            app:chipSpacingHorizontal="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/mainExerciseImage" />

        <TextView
            android:id="@+id/exerciseDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_item_description"
            android:layout_marginTop="60dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/categoryChipGroup"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/exerciseDescriptionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_item_description_text"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/exerciseDescription"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/stepsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"
            android:layout_marginTop="35dp"
            android:fontFamily="@font/lexend_font"
            android:text="Steps"
            android:textColor="@color/black_colour"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/exerciseDescriptionText" />

        <LinearLayout
            android:id="@+id/stepsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/stepsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/workoutNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_item_notes"
            android:layout_marginTop="60dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/stepsContainer"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/exerciseNotesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_left"

            android:text="@string/workout_item_notes_text"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/lexend_font"
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/black_colour"

            app:layout_constraintTop_toBottomOf="@id/workoutNotes"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
