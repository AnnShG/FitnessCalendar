<resources>
    <!-- Custom style for the DatePicker to force the Spinner look -->
    <style name="Widget.App.DatePickerSpinner" parent="android:Theme.Holo.Light.Dialog">
        <item name="android:datePickerMode">spinner</item>
        <item name="android:calendarViewShown">false</item>
    </style>

    <style name="Base.Theme.FitnessCalendar" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/lexend_font</item>
    </style>

    <style name="App.Custom.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/nav_bar_icon_bg_colour</item>
        <item name="android:width">64dp</item>
        <item name="android:height">32dp</item>
    </style>

    <style name="CalendarHeaderStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:textColor">@color/text_black_colour</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/lexend_font</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CustomChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_background_selector</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="chipIconTint">@color/chip_text_color</item>
        <item name="android:fontFamily">@font/lexend_font</item>
    </style>

    <style name="SelectedCircleIndicatorShape">
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedCorners" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="RoundedCornersGallery">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

<!--    <style name="CustomDropDownMenu" parent="Widget.AppCompat.PopupMenu">-->
<!--        <item name="android:itemBackground">@color/menu_bg_colour</item>-->
<!--        <item name="android:textColor">@color/menu_text_colour</item>-->
<!--    </style>-->

    <style name="Widget.App.PopupMenu.FixedLight" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:background">@color/menu_bg_colour</item>
        <item name="android:textColor">@color/menu_text_colour</item>
    </style>

    <style name="CustomOverflow" parent="Widget.MaterialComponents.PopupMenu.Overflow">
        <item name="android:src">@null</item>
    </style>

    <style name="Theme.FitnessCalendar" parent="Base.Theme.FitnessCalendar" />

    <style name="FilterLabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:fontFamily">@font/lexend_font</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_black_colour</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>